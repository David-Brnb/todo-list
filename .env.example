# Copy this file to `.env` and fill in the values, then restart with
# `npx expo start --clear`. All EXPO_PUBLIC_* vars are bundled into the client.

# --- Firebase ---
# From Firebase console: Project settings → General → Your apps → Web app (</>) config.
# Enable Email/Password under Authentication → Sign-in method.
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=        # e.g. my-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=     # e.g. my-project.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# --- Backend REST API ---
# Base URL with NO trailing slash. Use the deployed HTTPS URL, or your machine's
# LAN IP for local testing (NOT http://localhost on a physical device).
# Deployed backend (Google Cloud Run): https://to-do-860378882125.us-central1.run.app
# Local example: http://192.168.1.50:8080
EXPO_PUBLIC_API_URL=https://to-do-860378882125.us-central1.run.app
